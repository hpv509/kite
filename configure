#!/usr/bin/env bash
set -euo pipefail

prefix="${PREFIX:-build}"
build_type="${BUILD_TYPE:-Release}"
CC="${CC:-gcc}"
CXX="${CXX:-g++}"
home="${HOME}"

hdf5_prefix=""
eigen_prefix=""

compile_wp=0 # default
for arg in "$@"; do
	case "$arg" in
	--wavepacket=1) compile_wp=1 ;;
	--wavepacket=0) compile_wp=0 ;;
	--prefix=*) prefix="${arg#*=}" ;;
	--build-type=*) build_type="${arg#*=}" ;;
	--hdf5-prefix=*) hdf5_prefix="${arg#*=}" ;;
	--eigen-prefix=*) eigen_prefix="${arg#*=}" ;;
	CC=*) CC="${arg#*=}" ;;
	CXX=*) CXX="${arg#*=}" ;;
	*)
		echo "Unknown option: $arg" >&2
		exit 1
		;;
	esac
done

mkdir -p tools/Src build

openmp_cxxflags="-fopenmp"
openmp_ldflags="-fopenmp"

cxxflags="-std=c++17"
if [ "$build_type" = "Debug" ]; then
	cxxflags="$cxxflags -g -DDEBUG=1"
else
	cxxflags="$cxxflags -O3"
fi

hdf5_cflags=""
hdf5_libs=""
if [ -n "$hdf5_prefix" ]; then
	hdf5_cflags="-I${hdf5_prefix}/include"
	hdf5_libs="-L${hdf5_prefix}/lib -lhdf5_cpp -lhdf5"
else
	if command -v pkg-config >/dev/null 2>&1; then
		for pkg in hdf5-cxx hdf5_cpp hdf5; do
			if pkg-config --exists "$pkg"; then
				hdf5_cflags="$(pkg-config --cflags "$pkg")"
				hdf5_libs="$(pkg-config --libs "$pkg")"
				break
			fi
		done
	fi
fi

eigen_cflags=""
if [ -n "$eigen_prefix" ]; then
	eigen_cflags="-I${eigen_prefix}/include -I${eigen_prefix}/include/eigen3"
else
	if command -v pkg-config >/dev/null 2>&1 && pkg-config --exists eigen3; then
		eigen_cflags="$(pkg-config --cflags eigen3)"
	else
		eigen_cflags="-I${home}/include/eigen3"
	fi
fi

cat >config.mk <<EOF
PREFIX := $prefix
CC := $CC
CXX := $CXX
BUILD_TYPE := $build_type

CPPFLAGS := \
  -I${home}/include \
  ${eigen_cflags} \
  ${hdf5_cflags} \
  -Itools/Src \
  -ISrc -ISrc/Tools -ISrc/Lattice -ISrc/Hamiltonian -ISrc/Vector -ISrc/Simulation \
  -DCOMPILE_WAVEPACKET=${compile_wp}

CXXFLAGS := ${cxxflags} ${openmp_cxxflags}
LDFLAGS := ${openmp_ldflags} ${hdf5_libs}
DESTDIR ?=
EOF

echo "Configured."
echo "  HDF5 prefix: ${hdf5_prefix:-auto-detect}"
echo "  Eigen prefix: ${eigen_prefix:-auto-detect}"
